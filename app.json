{
  "expo": {
    "name": "Pastella Wallet",
    "slug": "pastella-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#282729"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pastella.wallet"
    },
    "android": {
      "package": "com.pastella.wallet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "monochromeImage": "./assets/logo-monochrome.png",
        "backgroundColor": "#282729"
      },
      "keystore": "./keys/pastella-release.keystore"
    },
    "web": {
      "favicon": "./assets/logo.png"
    }
  }
}
