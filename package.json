{
  "name": "pastella-mobile-wallet",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo prebuild",
    "build:clean": "expo prebuild --clean",
    "build:release": "npm run build && node scripts/setup-android-manifest.js && npm run setup-release-signing && cd android && gradlew.bat assembleRelease && move app\\build\\outputs\\apk\\release\\app-release.apk ..\\pastella-wallet.apk",
    "build:debug": "npm run build && node scripts/setup-android-manifest.js && cd android && gradlew.bat assembleRelease && move app\\build\\outputs\\apk\\release\\app-release.apk ..\\pastella-wallet.apk",
    "setup-release-signing": "node scripts/setup-release-signing.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.1",
    "@expo/vector-icons": "^15.0.3",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^2.0.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.10.1",
    "@react-navigation/stack": "^7.6.16",
    "expo": "^55.0.0-preview.5",
    "expo-camera": "^17.0.10",
    "expo-clipboard": "~55.0.1",
    "expo-haptics": "~55.0.1",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "^8.0.11",
    "expo-status-bar": "~55.0.1",
    "js-sha3": "^0.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.83.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.20.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "cross-env": "^10.1.0",
    "eas-cli": "^16.32.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
